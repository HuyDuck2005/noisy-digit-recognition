# Backend environment example.
# Copy this file to .env for local-only settings when needed.

APP_NAME="Noisy Digit Recognition API"
APP_ENV="development"
API_PREFIX="/api"

# Frontend dev server origin for future CORS setup.
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Upload limits for future real image processing.
MAX_UPLOAD_SIZE_MB=10
